@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix dc: <http://purl.org/dc/elements/1.1/>.
@prefix grddl: <http://www.w3.org/2003/g/data-view#>.
@prefix xml: <http://www.w3.org/XML/1998/namespace>.
@prefix ont: <http://example.org/ontology#>.

<http://example.org/ontology> a owl:Ontology;
    rdfs:comment "Ontology for the use case: Simple org chart. Just people and who they work for.".


#################################################################
#    Classes
#################################################################

# http://example.org/ontology#AbstractEntity
ont:AbstractEntity
    a owl:Class;
    rdfs:label "Abstract Entity"@en;
    rdfs:comment "Non-material entities existing conceptually, informationally, or socially, without physical form."@en;
    owl:disjointWith ont:Agent, ont:Material, ont:Process, ont:Quality, ont:SpatialRegion, ont:TemporalRegion.

# http://example.org/ontology#Agent
ont:Agent
    a owl:Class;
    rdfs:label "Agent"@en;
    rdfs:comment "Entities capable of intentional action and decision-making, including persons and organizations."@en;
    owl:disjointWith ont:AbstractEntity, ont:Material, ont:Process, ont:Quality, ont:SpatialRegion, ont:TemporalRegion.

# http://example.org/ontology#Company
ont:Company
    a owl:Class;
    rdfs:label "Company"@en;
    rdfs:comment "A commercial business organization formed to engage in enterprise and trade."@en;
    rdfs:subClassOf ont:Organization.

# http://example.org/ontology#Material
ont:Material
    a owl:Class;
    rdfs:label "Material"@en;
    rdfs:comment "Physical things with clear boundaries and material substance, including objects, artifacts, and natural entities."@en;
    owl:disjointWith ont:AbstractEntity, ont:Agent, ont:Process, ont:Quality, ont:SpatialRegion, ont:TemporalRegion.

# http://example.org/ontology#Organization
ont:Organization
    a owl:Class;
    rdfs:label "Organization"@en;
    rdfs:comment "A group of people structured around a particular purpose, such as a company, institution, or association."@en;
    rdfs:subClassOf ont:Agent;
    owl:disjointWith ont:Person.

# http://example.org/ontology#Person
ont:Person
    a owl:Class;
    rdfs:label "Person"@en;
    rdfs:comment "An individual human being capable of intentional action and decision-making."@en;
    rdfs:subClassOf ont:Agent;
    owl:disjointWith ont:Organization.

# http://example.org/ontology#Process
ont:Process
    a owl:Class;
    rdfs:label "Process"@en;
    rdfs:comment "Occurrences that unfold over time, including events, activities, and transformations."@en;
    owl:disjointWith ont:AbstractEntity, ont:Agent, ont:Material, ont:Quality, ont:SpatialRegion, ont:TemporalRegion.

# http://example.org/ontology#Quality
ont:Quality
    a owl:Class;
    rdfs:label "Quality"@en;
    rdfs:comment "Properties, attributes, or characteristics that describe other entities."@en;
    owl:disjointWith ont:AbstractEntity, ont:Agent, ont:Material, ont:Process, ont:SpatialRegion, ont:TemporalRegion.

# http://example.org/ontology#SpatialRegion
ont:SpatialRegion
    a owl:Class;
    rdfs:label "Spatial Region"@en;
    rdfs:comment "Places, locations, and spatial extents in physical or conceptual space."@en;
    owl:disjointWith ont:AbstractEntity, ont:Agent, ont:Material, ont:Process, ont:Quality, ont:TemporalRegion.

# http://example.org/ontology#TemporalRegion
ont:TemporalRegion
    a owl:Class;
    rdfs:label "Temporal Region"@en;
    rdfs:comment "Time intervals, periods, and temporal extents."@en;
    owl:disjointWith ont:AbstractEntity, ont:Agent, ont:Material, ont:Process, ont:Quality, ont:SpatialRegion.

# http://www.w3.org/2002/07/owl#test
owl:test
    a owl:Class;
    rdfs:label "test".

#################################################################
#    Object Properties
#################################################################

# http://example.org/ontology#employs
ont:employs
    a owl:ObjectProperty;
    rdfs:label "employs"@en;
    rdfs:comment "Indicates that a company has an employment or affiliation relationship with a person. Inverse of worksFor."@en;
    rdfs:subPropertyOf owl:topObjectProperty;
    rdfs:domain ont:Company;
    rdfs:range ont:Person;
    owl:inverseOf ont:worksFor.

# http://example.org/ontology#manages
ont:manages
    a owl:AsymmetricProperty, owl:IrreflexiveProperty, owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty;
    rdfs:label "manages"@en;
    rdfs:comment "Indicates that a person has direct managerial accountability over another person within an organization. Inverse of reportsTo."@en;
    rdfs:subPropertyOf owl:topObjectProperty;
    rdfs:domain ont:Person;
    rdfs:range ont:Person;
    owl:inverseOf ont:reportsTo.

# http://example.org/ontology#reportsTo
ont:reportsTo
    a owl:AsymmetricProperty, owl:IrreflexiveProperty, owl:ObjectProperty, owl:TransitiveProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty, owl:TransitiveProperty;
    rdfs:label "reports to"@en;
    rdfs:comment "Represents a formal hierarchical relationship in which one individual is directly accountable to another within an organization. Inverse of manages."@en;
    rdfs:subPropertyOf owl:topObjectProperty;
    rdfs:domain ont:Person;
    rdfs:range ont:Person;
    owl:inverseOf ont:manages.

# http://example.org/ontology#worksFor
ont:worksFor
    a owl:AsymmetricProperty, owl:IrreflexiveProperty, owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty;
    rdfs:label "works for"@en;
    rdfs:comment "Represents the state of being employed by or affiliated with an organization. Inverse of employs."@en;
    rdfs:subPropertyOf owl:topObjectProperty;
    rdfs:domain ont:Person;
    rdfs:range ont:Company;
    owl:inverseOf ont:employs.

#################################################################
#    Data Properties
#################################################################

# http://example.org/ontology#hasJobTitle
ont:hasJobTitle
    a owl:DatatypeProperty, owl:FunctionalProperty, owl:FunctionalProperty;
    rdfs:label "has job title"@en;
    rdfs:comment "The official designation or title of the position held by an individual within an organization."@en;
    rdfs:subPropertyOf owl:topDataProperty, owl:topObjectProperty;
    rdfs:domain ont:Person;
    rdfs:range xsd:string.

#################################################################
#    Annotation Properties
#################################################################



#################################################################
#    Individuals
#################################################################


